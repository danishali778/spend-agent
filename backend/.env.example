# Backend server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Supabase database and REST access
SUPABASE_DB_URL=postgresql+psycopg://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
SPENDAGENT_CACHE_ENABLED=true

# SpendAgent runtime
SPENDAGENT_DEMO_OWNER_ID=00000000-0000-0000-0000-000000000001
SPENDAGENT_PROMPT_BUNDLE_VERSION=v1.0.0
SPENDAGENT_PROVIDER_MODE=mock

# Groq provider
GROQ_API_KEY=
SPENDAGENT_GROQ_MODEL=llama-3.3-70b-versatile
SPENDAGENT_GROQ_TIMEOUT_SECONDS=30
SPENDAGENT_GROQ_TEMPERATURE=0.1

# Gemini provider
GEMINI_API_KEY=
SPENDAGENT_GEMINI_MODEL=gemini-2.5-flash
SPENDAGENT_GEMINI_TIMEOUT_SECONDS=30
SPENDAGENT_GEMINI_TEMPERATURE=0.1
